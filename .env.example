NODE_ENV=development
PORT=4700

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=uploady_app
POSTGRES_BIND_PORT=4701

REDIS_BIND_PORT=4702

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadminpassword
MINIO_BUCKET_NAME=uploady-app
MINIO_BIND_PORT=4703
MINIO_CONSOLE_PORT=4704

DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_BIND_PORT}/${POSTGRES_DB}
REDIS_URL=redis://localhost:${REDIS_BIND_PORT}
S3_ENDPOINT=http://localhost:${MINIO_BIND_PORT}
S3_REGION=auto
S3_BUCKET=${MINIO_BUCKET_NAME}
S3_ACCESS_KEY_ID=${MINIO_ROOT_USER}
S3_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
S3_FORCE_PATH_STYLE=true

AUTH_JWT_SECRET=dev-jwt-secret-change-me
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_MAGIC_LINK_TTL_SECONDS=900
APP_BASE_URL=http://localhost:4700

# Future auth variables:
# AUTH_JWT_ISSUER=uploady-app
# AUTH_JWT_AUDIENCE=uploady-app-web

# Future S3-compatible storage variables:
# S3_PUBLIC_BASE_URL=https://cdn.example.com/uploady-app
